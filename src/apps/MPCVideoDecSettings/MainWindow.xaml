<Window
    x:Class="MPCVideoDecSettings.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MPCVideoDecSettings.ViewModels">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="16" MaxWidth="640">

                <!-- Video settings -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Video settings" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="4" Padding="16">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Number of decoding threads" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                          SelectedIndex="{x:Bind ViewModel.ThreadNumber, Mode=TwoWay}">
                                    <ComboBoxItem Content="Auto" />
                                    <ComboBoxItem Content="1" /><ComboBoxItem Content="2" />
                                    <ComboBoxItem Content="3" /><ComboBoxItem Content="4" />
                                    <ComboBoxItem Content="5" /><ComboBoxItem Content="6" />
                                    <ComboBoxItem Content="7" /><ComboBoxItem Content="8" />
                                    <ComboBoxItem Content="9" /><ComboBoxItem Content="10" />
                                    <ComboBoxItem Content="11" /><ComboBoxItem Content="12" />
                                    <ComboBoxItem Content="13" /><ComboBoxItem Content="14" />
                                    <ComboBoxItem Content="15" /><ComboBoxItem Content="16" />
                                </ComboBox>
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Scan type" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                          SelectedIndex="{x:Bind ViewModel.ScanType, Mode=TwoWay}">
                                    <ComboBoxItem Content="Auto" />
                                    <ComboBoxItem Content="Top-Field First" />
                                    <ComboBoxItem Content="Bottom-Field First" />
                                    <ComboBoxItem Content="Progressive" />
                                </ComboBox>
                            </Grid>
                            <CheckBox Content="Read AR from stream" IsThreeState="True"
                                      IsChecked="{x:Bind ViewModel.ArMode, Mode=TwoWay}" />
                            <CheckBox Content="Skip B-Frames" IsChecked="{x:Bind ViewModel.DiscardMode, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Hardware acceleration -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Hardware acceleration" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="4" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Codecs:" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.HwCodecs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ToggleOption">
                                        <CheckBox Content="{x:Bind Label}" IsChecked="{x:Bind IsEnabled, Mode=TwoWay}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Preferred decoder" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                          SelectedIndex="{x:Bind ViewModel.HwDecoder, Mode=TwoWay}">
                                    <ComboBoxItem Content="DXVA2" />
                                    <ComboBoxItem Content="D3D11, DXVA2" />
                                    <ComboBoxItem Content="D3D11cb" />
                                    <ComboBoxItem Content="D3D12cb" />
                                    <ComboBoxItem Content="NVDEC (Nvidia only)" />
                                </ComboBox>
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Adapter (VendorId:DeviceId, hex)" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{x:Bind ViewModel.HwAdapter, Mode=TwoWay}" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="DXVA (H.264) Compatibility check" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                          SelectedIndex="{x:Bind ViewModel.DxvaCheckCompatibility, Mode=TwoWay}">
                                    <ComboBoxItem Content="Full check" />
                                    <ComboBoxItem Content="Skip level check" />
                                    <ComboBoxItem Content="Skip ref frame check" />
                                    <ComboBoxItem Content="Skip all checks" />
                                </ComboBox>
                            </Grid>
                            <CheckBox Content="Disable DXVA for SD (H.264)" IsChecked="{x:Bind ViewModel.DisableDxvaSd, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Output formats -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Output formats" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="4" Padding="16">
                        <StackPanel Spacing="12">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.PixelFormatToggles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ToggleOption">
                                        <CheckBox Content="{x:Bind Label}" IsChecked="{x:Bind IsEnabled, Mode=TwoWay}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <CheckBox Content="Convert to RGB" IsChecked="{x:Bind ViewModel.SwConvertToRgb, Mode=TwoWay}" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="RGB output levels:" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                          SelectedIndex="{x:Bind ViewModel.SwRgbLevels, Mode=TwoWay}">
                                    <ComboBoxItem Content="PC (0-255)" />
                                    <ComboBoxItem Content="TV (16-235)" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Status (read-only, live from shared memory) -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Status" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="4" Padding="16">
                        <Grid>
                            <TextBlock Text="Not connected (no MPCVideoDec instance is currently decoding)"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind ViewModel.NotConnectedVisibility, Mode=OneWay}" />
                            <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.ConnectedVisibility, Mode=OneWay}">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Input format:" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Status.InputFormat, Mode=OneWay}" />
                                </Grid>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Frame size:" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Status.FrameSize, Mode=OneWay}" />
                                </Grid>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Output format:" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Status.OutputFormat, Mode=OneWay}" />
                                </Grid>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Decoder:" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Status.ActiveDecoder, Mode=OneWay}" />
                                </Grid>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Graphics Adapter:" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Status.GraphicsAdapter, Mode=OneWay}" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Reset" Command="{x:Bind ViewModel.ResetCommand}" />
            <Button Content="Reload" Command="{x:Bind ViewModel.LoadCommand}" />
            <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
